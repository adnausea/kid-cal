# ──────────────────────────────────────────────
# Email Provider
# ──────────────────────────────────────────────
# 'yahoo' or 'icloud' — sets IMAP host/port automatically
# For other providers, set IMAP_HOST and IMAP_PORT manually
EMAIL_PROVIDER=icloud

# IMAP credentials
# iCloud:  use your @icloud.com / @me.com address
# Yahoo:   use your @yahoo.com address
# Both require an app-specific password (not your regular password)
IMAP_USER=jdoe@icloud.com
IMAP_PASSWORD=abcd-efgh-ijkl-mnop

# Override IMAP defaults if using a custom provider (e.g. Gmail, Outlook)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# ──────────────────────────────────────────────
# School Email Filtering
# ──────────────────────────────────────────────
# Comma-separated domains — emails from these domains are processed
SCHOOL_SENDER_DOMAINS=lincolnelementary.org,unified-district.edu

# Comma-separated individual addresses (for senders using personal email)
SCHOOL_SENDER_ADDRESSES=mrs.johnson@gmail.com,pta.president@outlook.com

# ──────────────────────────────────────────────
# Claude API (Anthropic)
# ──────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ──────────────────────────────────────────────
# Calendar Provider
# ──────────────────────────────────────────────
# 'google' or 'icloud'
CALENDAR_PROVIDER=icloud

# --- iCloud Calendar (required when CALENDAR_PROVIDER=icloud) ---
# Uses CalDAV with your Apple ID
# Generate an app-specific password at https://appleid.apple.com
# (Sign-In and Security → App-Specific Passwords)
ICLOUD_USERNAME=jdoe@icloud.com
ICLOUD_APP_PASSWORD=abcd-efgh-ijkl-mnop

# --- Google Calendar (required when CALENDAR_PROVIDER=google) ---
# Uses a service account — set up at https://console.cloud.google.com
# 1. Create a project → enable Google Calendar API
# 2. Create a service account → download JSON key
# 3. Share your calendar with the service account email
# GOOGLE_SERVICE_ACCOUNT_EMAIL=kid-cal@my-project-123456.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID=family-calendar@group.calendar.google.com

# ──────────────────────────────────────────────
# Telegram Notifications
# ──────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your new bot → then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat ID in the response JSON
TELEGRAM_BOT_TOKEN=1234567890:AAHx9k_ZzB3vRJcmP0dWxYfE8qNlM2kGhT4
TELEGRAM_CHAT_ID=9876543210

# ──────────────────────────────────────────────
# Grade & Content Filtering
# ──────────────────────────────────────────────
# Your child's current grade — Claude filters events to this grade + school-wide
CHILD_GRADE=5

# Comma-separated keywords — events/action items containing these are dropped
EXCLUDE_KEYWORDS=kindergarten,pre-k,first grade

# Comma-separated — emails with these words in the subject line are skipped entirely
BLOCKED_SUBJECT_KEYWORDS=lunch menu,athletic booster

# ──────────────────────────────────────────────
# Polling & Reminders
# ──────────────────────────────────────────────
POLL_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_MINUTES=15

# IANA timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/Los_Angeles

# Hour (0-23) when morning reminders are sent
MORNING_REMINDER_HOUR=7

# ──────────────────────────────────────────────
# Database & Logging
# ──────────────────────────────────────────────
# SQLite database path (Docker uses /data/kid-cal.db via volume)
DB_PATH=./kid-cal.db

# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
