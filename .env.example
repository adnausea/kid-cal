# ── Email Provider ────────────────────────────
# EMAIL_PROVIDER=yahoo
# EMAIL_PROVIDER=icloud

# ── IMAP ─────────────────────────────────────
# IMAP_HOST=imap.mail.me.com
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=

# ── School Filtering ─────────────────────────
# SCHOOL_SENDER_DOMAINS=school.org,district.edu
# SCHOOL_SENDER_ADDRESSES=teacher@gmail.com

# ── Claude API ───────────────────────────────
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── Calendar Provider ────────────────────────
# CALENDAR_PROVIDER=google
# CALENDAR_PROVIDER=icloud

# ── Google Calendar ──────────────────────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_CALENDAR_ID=

# ── iCloud Calendar ──────────────────────────
# ICLOUD_USERNAME=
# ICLOUD_APP_PASSWORD=

# ── Telegram ─────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Grade & Content Filtering ────────────────
# CHILD_GRADE=5
# EXCLUDE_KEYWORDS=kindergarten,pre-k
# BLOCKED_SUBJECT_KEYWORDS=lunch menu

# ── Polling & Reminders ─────────────────────
# POLL_INTERVAL_MINUTES=5
# REMINDER_CHECK_INTERVAL_MINUTES=15
# TIMEZONE=America/New_York
# MORNING_REMINDER_HOUR=7

# ── Database & Logging ──────────────────────
# DB_PATH=./kid-cal.db
# LOG_LEVEL=info
